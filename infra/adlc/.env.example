# AgentOps telemetry egress (opt-in) — consumed by the `otel-collector-central`
# service under the `central` compose profile. Copy to `.env` (gitignored) and
# fill in. Leaving AGENTIC_CENTRAL_OTLP_ENDPOINT empty keeps egress DISABLED.
# See ADR-0004 and skills/agentops/SKILL.md.

# Your external OTLP/HTTP egress endpoint (the aggregation consumer is out of
# framework scope). MUST be https in the cloud. Empty => no egress (default).
AGENTIC_CENTRAL_OTLP_ENDPOINT=

# Per-project bearer token issued by your egress endpoint. Required when the
# endpoint is set. Treat as a secret; never commit the filled-in .env.
AGENTIC_CENTRAL_API_KEY=

# Fleet identity. project/org are the REAL names (clear-text) — comparison
# needs them. Set project to your real project name/slug.
AGENTIC_PROJECT_SLUG=CHANGE-ME
AGENTIC_ORG_SLUG=commerzreal

# Pseudonymous developer id — the ONLY developer identifier that ever leaves
# the machine. Set once by /init-project, e.g.
#   python3 -c "import hashlib,subprocess; e=subprocess.check_output(['git','config','user.email']).strip().lower(); print(hashlib.sha256(e+b'agentic-salt').hexdigest()[:16])"
AGENTIC_DEVELOPER_HASH=

# Framework (plugin) version — lets dashboards segment by framework release.
AGENTIC_FRAMEWORK_VERSION=0.1.0

# NOTE: catalyst is a purely static, PUBLIC page (project ADR-0001/0002) — there is no
# auth, no IdP, and no e2e credential. The milestone-end e2e gate is fully hermetic
# (infra/run-e2e-gate.sh), so no identity-provider or token config lives here.
