COMPOSE_PROJECT_NAME=catalyst
DEV_WRITE_TOKEN=dev-write-token-not-a-secret

# --- Host-port block (ADR-0035) -----------------------------------------
# Allocated once by /init-project so parallel projects on one machine
# never collide on published ports; committed and project-stable (the
# project .mcp.json and the OTEL endpoint in .claude/settings.json are
# derived from these). Compose maps them onto the canonical container-
# internal ports, which never change. catalyst is frontend-only (project
# ADR-0001): there is no backend/db host port.
ADLC_PORT_BASE=20200
ADLC_FRONTEND_HOST_PORT=20200
ADLC_STRUCTURIZR_MCP_HOST_PORT=20203
ADLC_STRUCTURIZR_UI_HOST_PORT=20204
ADLC_POSTGRES_MCP_HOST_PORT=20205
ADLC_PLAYWRIGHT_MCP_HOST_PORT=20206
ADLC_OTLP_GRPC_HOST_PORT=20207
ADLC_OTLP_HTTP_HOST_PORT=20208
PROD_HOST_PORT=20209
FRONTEND_HOST_PORT=20210
